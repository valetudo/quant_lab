# Quant Lab — environment variables template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ---------- Required: data provider ----------

# FMP (Financial Modeling Prep) API key — Premium subscription is required for
# the full historical depth + fundamentals coverage the strategies depend on.
# https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# ---------- Optional: path overrides ----------
# These override paths in `configs/global.yaml`. Leave unset to use defaults
# resolved relative to the repo root (see `configs/global.yaml`).

# Where price/fundamentals parquets live. Defaults to <repo>/data_storage.
# QUANT_LAB_DATA_PATH=

# Where the bond snapshots DuckDB lives. Defaults to <repo>/../bonds/bonds.db
# (the Borsa Italiana scraper output, when running alongside the bonds repo).
# QUANT_LAB_BONDS_DB_PATH=

# Global data storage (cross-system) DuckDB. Used by some import scripts.
# GDS_DB_PATH=

# ---------- Optional: source override for bond migration script ----------
# Only used by `scripts/migrate_bonds_db.py`. Defaults to <repo>/../bonds/bonds.db.
# QUANT_LAB_BONDS_SOURCE=
